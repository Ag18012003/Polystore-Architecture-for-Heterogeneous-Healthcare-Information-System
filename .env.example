# ── POLYSTORE Architecture – Local Database Configuration ─────────────────────
#
# Copy this file to backend/.env and fill in your values.
# Both databases must be running locally before starting the server.
#
# ── LOCAL MONGODB ──────────────────────────────────────────────────────────────
# Start MongoDB: mongod  (or use mongosh to verify: mongosh --eval "db.adminCommand('ping')")
MONGODB_URI=mongodb://127.0.0.1:27017/healthcare

# ── LOCAL MYSQL ────────────────────────────────────────────────────────────────
# Start MySQL: sudo systemctl start mysql  (or MySQL Workbench / XAMPP)
# Create the database first: CREATE DATABASE healthcare_db;
# Tables are created automatically when the server starts.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=healthcare_db

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret

# ── APP ────────────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:5173

# ── CLERK (user auth) ──────────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── CLOUDINARY (image uploads) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── STRIPE (payments, optional) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
